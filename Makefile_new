BUILD_BINARY := $(wildcard build)

DEBUG_BUILD_COMMAND = build.c -o build -Wall -Wextra -pedantic -Werror

existing_binaries:

ifeq ($(BUILD_BINARY),)
	@gcc build.c -o build
endif

full: existing_binaries
	@./build gcc -e

setup: existing_binaries
	@./build gcc

base:
	@gcc $(DEBUG_BUILD_COMMAND)
	@./build zig -e

zig:
	@zig cc $(DEBUG_BUILD_COMMAND)
	@./build zig
